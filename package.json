{
  "name": "glean",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "sh scripts/dev.sh",
    "dev:real": "GLEAN_PROCESSOR_MODE=real sh scripts/dev.sh",
    "dev:demo": "GLEAN_PROCESSOR_MODE=demo sh scripts/dev.sh",
    "backend": "PATH=\"$HOME/Library/Python/3.9/bin:$PATH\" python3 -m uvicorn app.main:app --host 127.0.0.1 --port 8787 --reload --app-dir backend",
    "backend:real": "PATH=\"$HOME/Library/Python/3.9/bin:$PATH\" GLEAN_PROCESSOR_MODE=real python3 -m uvicorn app.main:app --host 127.0.0.1 --port 8787 --reload --app-dir backend",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
